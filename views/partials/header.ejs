<header id="top-header">
  <span class="siteName">
    <a href="/" title="Return to home page">CSE Motors</a>
  </span>

  <div id="tools">
    <% if (loggedin) { %>

      <!-- Welcome link (goes to account management) -->
      <a href="/account" title="Go to account management">
        Welcome <%= accountData.account_firstname %>
      </a>

      <!-- Logout link -->
      <a href="/account/logout" title="Logout">Logout</a>

    <% } else { %>

      <!-- My Account (only when NOT logged in) -->
      <a title="Click to log in" href="/account/login">My Account</a>

    <% } %>
  </div>
</header>