<section class="vehicle-detail">

  <!-- Image -->
  <div class="vehicle-image">
    <img 
      src="<%= vehicle.inv_image %>" 
      alt="<%= vehicle.inv_make %> <%= vehicle.inv_model %>"
      onerror="this.src='/images/no-image.png'"
    >
  </div>

  <!-- Info -->
  <div class="vehicle-info">
    <h2 class="vehicle-title">
      <%= vehicle.inv_year %> <%= vehicle.inv_make %> <%= vehicle.inv_model %>
    </h2>

    <p class="price">$<%= Number(vehicle.inv_price).toLocaleString() %></p>

    <p class="description"><%= vehicle.inv_description %></p>

    <ul class="specs">
      <li><span>Year</span><strong><%= vehicle.inv_year %></strong></li>
      <li><span>Mileage</span><strong><%= vehicle.inv_miles %> km</strong></li>
      <li><span>Color</span><strong><%= vehicle.inv_color %></strong></li>
    </ul>

    <div class="actions">
      <button class="cta-btn">Contact Dealer</button>
      <button class="secondary-btn">Save Vehicle</button>
    </div>
  </div>

</section>