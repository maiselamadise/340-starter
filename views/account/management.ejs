<!-- Title -->
<% if (title) { %>
  <h1 class="page-title"><%= title %></h1>
<% } %>

<!-- Flash Messages -->
<%- messages() %>

<!-- Validation Errors -->
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>

<div class="management-links">

  <!-- Welcome -->
  <h2>Welcome <%= accountData.account_firstname %></h2>

  <!-- Update Link (REQUIRED) -->
  <a href="/account/update/<%= accountData.account_id %>">
    Update Account Information
  </a>

  <!-- Admin / Employee ONLY -->
  <% if (accountData.account_type === "Admin" || accountData.account_type === "Employee") { %>
    
    <h3>Inventory Management</h3>
    
    <p>
      <a href="/inv/">Manage Inventory</a>
    </p>

  <% } %>

</div>