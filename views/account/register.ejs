<main>
  <h1><%= title %></h1>

  <% if (messages) { %>
    <ul class="flash">
      <% 
        let msgArray = Array.isArray(messages) ? messages : [messages];
        msgArray.forEach(message => { 
      %>
        <li><%= message %></li>
      <% }) %>
    </ul>
  <% } %>

  <form action="/account/register" method="post" class="register-form">

    <label for="account_firstname">First Name</label>
    <input 
      type="text" 
      name="account_firstname" 
      id="account_firstname" 
      required
    >

    <label for="account_lastname">Last Name</label>
    <input 
      type="text" 
      name="account_lastname" 
      id="account_lastname" 
      required
    >

    <label for="account_email">Email</label>
    <input 
      type="email" 
      name="account_email" 
      id="account_email" 
      required
    >

    <label for="account_password">Password</label>
    <input 
      type="password" 
      name="account_password" 
      id="account_password" 
      required
      minlength="12"
      pattern="^(?=.*[A-Z])(?=.*[0-9])(?=.*[!@#$%^&*]).{12,}$"
      title="Must be at least 12 characters, include a capital letter, number, and special character"
    >

    <button type="submit">Register</button>

  </form>

  <p>Password must be at least 12 characters and include:</p>
  <ul>
    <li>At least 1 capital letter</li>
    <li>At least 1 number</li>
    <li>At least 1 special character</li>
  </ul>

</main>

